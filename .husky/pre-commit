#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Proyecto vanilla HTML/CSS/JS — no hay TS ni ESLint.
# Gate: tests unitarios (vitest) sobre los modulos JS compartidos.
echo "Running vitest unit tests..."
pnpm test || {
  echo "Vitest unit tests failed. Fix before committing."
  exit 1
}

echo "All checks passed"
